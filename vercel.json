{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate --no-engine && npx next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "regions": ["fra1"],
  "env": {
    "PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING": "1",
    "PRISMA_SKIP_DATABASE_URL_VALIDATION": "1"
  }
}
